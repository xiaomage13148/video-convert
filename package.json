    "cross-env": "^10.1.0",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "postcss": "^8.5.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^2.5.5",
    "tailwindcss": "3.4.17",
    "tailwindcss-animate": "^1.0.7",
